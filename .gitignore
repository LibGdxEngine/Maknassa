# Node (app/ deps, plus any stray node_modules npm creates at the repo root)
node_modules/

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Packaging / build output
build/
dist/
# bundled Chromium fetched at build time (large); inline comments aren't valid in .gitignore
packaging/ms-playwright/
# generated AppImage staging
packaging/**/*.AppDir/

# Playwright persistent profile — contains your Facebook session cookies. NEVER commit.
.profiles/

# Local data / debug artifacts
*.db
*.db-wal
*.db-shm
debug/
.omc/

# Inspection dumps may contain scraped names/profile data
inspect*.json
